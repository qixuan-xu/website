<!-- 控制面板 -->
<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>MC Panel</title>
<link rel="icon" type="image/png" href="../favicon.png"/>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07111f;
  --bg1:#0b1828;
  --bg2:#0f1e30;
  --bg3:#162435;
  --border:rgba(255,255,255,0.07);
  --border2:rgba(255,255,255,0.13);
  --green:#40916c;
  --green2:#2d6a4f;
  --green3:rgba(27,67,50,0.6);
  --greentext:#74b89a;
  --greendim:#52796f;
  --text:#e8f0f8;
  --muted:rgba(200,220,240,0.5);
  --hint:rgba(150,180,210,0.3);
  --red:#e06c75;
  --amber:#f0a500;
  --blue:#4a9eff;
  --online:#40916c;
}
*{scrollbar-width:thin;scrollbar-color:rgba(64,145,108,0.2) transparent}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-thumb{background:rgba(64,145,108,0.25);border-radius:2px}

body{
  font-family:'Syne',sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
}
body::before{
  content:'';
  position:fixed;inset:0;z-index:0;
  background:
    radial-gradient(ellipse 50% 40% at 15% 20%, rgba(64,145,108,0.1) 0%, transparent 65%),
    radial-gradient(ellipse 40% 35% at 85% 75%, rgba(79,140,255,0.06) 0%, transparent 60%),
    linear-gradient(160deg,#060e1c,#07111f 60%,#080f1a);
}
body::after{
  content:'';
  position:fixed;inset:0;z-index:0;
  background-image:
    linear-gradient(rgba(64,145,108,0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(64,145,108,0.03) 1px,transparent 1px);
  background-size:40px 40px;
  pointer-events:none;
}

.layout{
  position:relative;z-index:1;
  width:100%;max-width:780px;
  margin:0 auto;
  padding:24px 20px 48px;
}

/* HEADER */
.hdr{
  display:flex;align-items:center;gap:14px;
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);
  border-radius:16px;
  padding:14px 18px;
  margin-bottom:20px;
  backdrop-filter:blur(16px);
}
.logo-icon{
  width:38px;height:38px;border-radius:9px;
  background:rgba(45,106,79,0.4);
  border:1px solid rgba(64,145,108,0.3);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.logo-icon svg{width:17px;height:17px;fill:none;stroke:#74b89a;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.hdr-info{flex:1;min-width:0}
.hdr-title{font-size:15px;font-weight:700;line-height:1.2}
.hdr-sub{
  font-family:'JetBrains Mono',monospace;
  font-size:11px;color:var(--greendim);margin-top:2px;
}
.hdr-right{display:flex;align-items:center;gap:10px}
.status-pill{
  display:flex;align-items:center;gap:6px;
  background:rgba(0,0,0,0.2);
  border:1px solid var(--border);
  border-radius:20px;padding:5px 12px;
}
.sdot{
  width:7px;height:7px;border-radius:50%;
  background:var(--red);flex-shrink:0;
}
.sdot.on{
  background:var(--online);
  box-shadow:0 0 6px rgba(64,145,108,0.7);
  animation:blink 2.5s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.35}}
.spill-txt{
  font-family:'JetBrains Mono',monospace;
  font-size:11px;color:var(--muted);
}
.icon-btn{
  background:rgba(255,255,255,0.04);
  border:1px solid var(--border);
  border-radius:8px;width:32px;height:32px;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:.15s;color:var(--muted);flex-shrink:0;
}
.icon-btn:hover{background:rgba(255,255,255,0.08);color:var(--text);border-color:var(--border2)}
.icon-btn svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round}

/* STATS */
.stats-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:10px;
  margin-bottom:20px;
}
.stat{
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);
  border-radius:12px;padding:12px 14px;
}
.stat-lbl{
  font-family:'JetBrains Mono',monospace;
  font-size:10px;color:var(--hint);
  text-transform:uppercase;letter-spacing:.08em;
  margin-bottom:5px;
}
.stat-val{
  font-family:'JetBrains Mono',monospace;
  font-size:20px;font-weight:600;color:var(--text);line-height:1;
}
.stat-val.good{color:var(--greentext)}
.stat-val.warn{color:var(--amber)}
.stat-val.bad{color:var(--red)}

/* TWO COL */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}

/* SECTIONS */
.section{
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
}
.sec-hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 14px;
  border-bottom:1px solid var(--border);
  background:rgba(0,0,0,0.15);
}
.sec-title{
  font-family:'JetBrains Mono',monospace;
  font-size:10px;color:var(--greendim);
  text-transform:uppercase;letter-spacing:.1em;
}
.sec-action{
  font-family:'JetBrains Mono',monospace;
  font-size:11px;color:var(--hint);
  background:none;border:none;cursor:pointer;
  padding:2px 6px;border-radius:4px;
  transition:.15s;
}
.sec-action:hover{color:var(--greentext);background:rgba(64,145,108,0.1)}
.sec-body{padding:12px 14px}

/* PLAYERS */
.player-list{display:flex;flex-direction:column;gap:6px}
.player-row{
  display:flex;align-items:center;gap:10px;
  background:rgba(0,0,0,0.15);
  border:1px solid var(--border);
  border-radius:9px;padding:8px 10px;
  transition:.15s;
}
.player-row:hover{border-color:var(--border2);background:rgba(255,255,255,0.04)}
.avatar{
  width:28px;height:28px;border-radius:6px;
  background:var(--bg3);
  display:flex;align-items:center;justify-content:center;
  font-family:'JetBrains Mono',monospace;
  font-size:11px;font-weight:600;flex-shrink:0;
}
.pname{font-size:13px;font-weight:600;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pbadge{
  font-family:'JetBrains Mono',monospace;
  font-size:10px;padding:2px 7px;border-radius:4px;white-space:nowrap;
}
.pbadge.op{background:var(--green3);color:var(--greentext);border:1px solid rgba(64,145,108,0.3)}
.pbadge.new{background:rgba(74,158,255,.1);color:var(--blue);border:1px solid rgba(74,158,255,.2)}
.ptime{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--hint);white-space:nowrap}
.pdot{width:6px;height:6px;border-radius:50%;background:var(--online);flex-shrink:0}
.empty-state{
  text-align:center;padding:20px 0;
  font-family:'JetBrains Mono',monospace;
  font-size:12px;color:var(--hint);
}

/* QUICK ACTIONS */
.qactions{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:12px 14px}
.qbtn{
  background:rgba(0,0,0,0.2);
  border:1px solid var(--border);
  border-radius:9px;
  padding:10px 8px;
  cursor:pointer;text-align:center;
  transition:.14s;
}
.qbtn:hover{background:rgba(255,255,255,0.05);border-color:var(--border2);transform:translateY(-1px)}
.qbtn:active{transform:translateY(0)}
.qbtn-icon{font-size:15px;margin-bottom:4px}
.qbtn-lbl{font-size:11px;color:var(--muted);font-weight:600;font-family:'Syne',sans-serif}

/* COMMAND */
.cmd-section{margin-bottom:14px}
.cmd-inner{padding:12px 14px}
.cmd-row{display:flex;gap:8px;align-items:center}
.cmd-pre{
  font-family:'JetBrains Mono',monospace;
  font-size:13px;color:var(--greentext);flex-shrink:0;
}
#ci{
  flex:1;background:transparent;border:none;outline:none;
  color:var(--text);
  font-family:'JetBrains Mono',monospace;
  font-size:13px;
  caret-color:var(--greentext);
}
#ci::placeholder{color:var(--hint)}
.sbtn{
  background:rgba(45,106,79,0.4);
  border:1px solid rgba(64,145,108,0.3);
  border-radius:7px;width:28px;height:28px;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:.14s;flex-shrink:0;
}
.sbtn:hover{background:rgba(64,145,108,0.5)}
.sbtn svg{width:12px;height:12px;fill:#c8e6c9}

/* OUTPUT */
.out-section{margin-bottom:0}
.out-win-hdr{
  display:flex;align-items:center;gap:6px;
  padding:8px 12px;
  background:rgba(0,0,0,0.2);
  border-bottom:1px solid var(--border);
}
.wdots{display:flex;gap:5px}
.wd{width:8px;height:8px;border-radius:50%}
.wd1{background:rgba(224,108,117,.3)}
.wd2{background:rgba(240,165,0,.3)}
.wd3{background:rgba(64,145,108,.3)}
.out-title-lbl{
  font-family:'JetBrains Mono',monospace;
  font-size:10px;color:var(--hint);margin-left:auto;
}
#out{
  font-family:'JetBrains Mono',monospace;
  font-size:12px;color:var(--greendim);
  padding:10px 14px;
  min-height:100px;max-height:180px;
  overflow-y:auto;
  line-height:1.8;
  white-space:pre-wrap;word-break:break-all;
}
.ol.ok{color:var(--greentext)}
.ol.er{color:var(--red)}
.ol.inf{color:var(--hint)}

/* entrance */
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.layout{animation:fadeUp .4s ease both}

@media(max-width:580px){
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .two-col{grid-template-columns:1fr}
}
</style>
</head>
<body>

<div class="layout">

  <!-- HEADER -->
  <div class="hdr">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
    </div>
    <div class="hdr-info">
      <div class="hdr-title">MC Panel</div>
      <div class="hdr-sub">mc.qixuan.net</div>
    </div>
    <div class="hdr-right">
      <div class="status-pill">
        <div class="sdot" id="sdot"></div>
        <span class="spill-txt" id="stext">—</span>
      </div>
      <button class="icon-btn" id="map-btn" title="Open Map">
        <svg viewBox="0 0 24 24"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
      </button>
      <button class="icon-btn" id="logout-btn" title="Logout">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </button>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats-grid">
    <div class="stat">
      <div class="stat-lbl">Online</div>
      <div class="stat-val good" id="s-online">—</div>
    </div>
    <div class="stat">
      <div class="stat-lbl">TPS</div>
      <div class="stat-val" id="s-tps">—</div>
    </div>
    <div class="stat">
      <div class="stat-lbl">Memory</div>
      <div class="stat-val" id="s-mem">—</div>
    </div>
    <div class="stat">
      <div class="stat-lbl">Uptime</div>
      <div class="stat-val" id="s-uptime">—</div>
    </div>
  </div>

  <!-- PLAYERS + QUICK ACTIONS -->
  <div class="two-col">
    <div class="section">
      <div class="sec-hdr">
        <span class="sec-title">Players</span>
        <button class="sec-action" id="rfbtn">↻ refresh</button>
      </div>
      <div class="sec-body">
        <div class="player-list" id="player-list">
          <div class="empty-state">— loading —</div>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="sec-hdr">
        <span class="sec-title">Quick Actions</span>
      </div>
      <div class="qactions">
        <button class="qbtn" onclick="sendCmd('save-all')">
          <div class="qbtn-icon">💾</div>
          <div class="qbtn-lbl">Save</div>
        </button>
        <button class="qbtn" onclick="sendCmd('list')">
          <div class="qbtn-icon">👥</div>
          <div class="qbtn-lbl">List</div>
        </button>
        <button class="qbtn" onclick="sendCmd('tps')">
          <div class="qbtn-icon">📊</div>
          <div class="qbtn-lbl">TPS</div>
        </button>
        <button class="qbtn" onclick="sendCmd('time set day')">
          <div class="qbtn-icon">☀️</div>
          <div class="qbtn-lbl">Day</div>
        </button>
        <button class="qbtn" onclick="sendCmd('weather clear')">
          <div class="qbtn-icon">🌤</div>
          <div class="qbtn-lbl">Clear</div>
        </button>
        <button class="qbtn" onclick="openMap()">
          <div class="qbtn-icon">🗺</div>
          <div class="qbtn-lbl">Map</div>
        </button>
      </div>
    </div>
  </div>

  <!-- COMMAND INPUT -->
  <div class="section cmd-section">
    <div class="sec-hdr">
      <span class="sec-title">Console</span>
    </div>
    <div class="cmd-inner">
      <div class="cmd-row">
        <span class="cmd-pre">/</span>
        <input type="text" id="ci" placeholder="enter command…" autocomplete="off" autocorrect="off" spellcheck="false"/>
        <button class="sbtn" onclick="customCmd()">
          <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- OUTPUT -->
  <div class="section out-section">
    <div class="out-win-hdr">
      <div class="wdots">
        <div class="wd wd1"></div>
        <div class="wd wd2"></div>
        <div class="wd wd3"></div>
      </div>
      <span class="out-title-lbl">output</span>
    </div>
    <div id="out"></div>
  </div>

</div>

<script>
const API = "https://api.mc.qixuan.net";
const token = sessionStorage.getItem("mc_token");

// redirect if not logged in
if (!token) window.location.href = "index.html";

const startTime = Date.now();
const joinTimes = {};

function log(msg, type = "inf") {
  const out = document.getElementById("out");
  const line = document.createElement("div");
  line.className = "ol " + type;
  const ts = new Date().toLocaleTimeString("en-GB", {hour12:false});
  line.textContent = "[" + ts + "] " + msg;
  out.appendChild(line);
  out.scrollTop = out.scrollHeight;
}

async function sendCmd(cmd) {
  log("/" + cmd, "inf");
  try {
    const res = await fetch(API + "/cmd", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + token
      },
      body: JSON.stringify({cmd})
    });
    if (res.status === 401) {
      sessionStorage.removeItem("mc_token");
      window.location.href = "index.html";
      return null;
    }
    const text = await res.text();
    text.split("\n").forEach(l => { if (l.trim()) log(l, "ok"); });
    return text;
  } catch(e) {
    log("Error: " + e.message, "er");
    return null;
  }
}

function customCmd() {
  const v = document.getElementById("ci").value.trim();
  if (!v) return;
  sendCmd(v);
  document.getElementById("ci").value = "";
}
document.getElementById("ci").addEventListener("keydown", e => {
  if (e.key === "Enter") customCmd();
});

function openMap() { window.open("https://map.qixuan.net", "_blank"); }

document.getElementById("map-btn").addEventListener("click", openMap);
document.getElementById("logout-btn").addEventListener("click", () => {
  sessionStorage.removeItem("mc_token");
  window.location.href = "index.html";
});

const COLORS = ["#40916c","#4a9eff","#f0a500","#e06c75","#9b72cf","#52b0a0","#e88040","#7aaa50"];
function nameColor(name) {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) & 0xffff;
  return COLORS[h % COLORS.length];
}
function initials(name) { return name.slice(0, 2).toUpperCase(); }
function elapsed(ms) {
  const s = Math.floor(ms / 1000);
  if (s < 60) return s + "s";
  if (s < 3600) return Math.floor(s / 60) + "m";
  return Math.floor(s / 3600) + "h";
}

function renderPlayers(list) {
  const pl = document.getElementById("player-list");
  document.getElementById("s-online").textContent = list ? list.length : "0";
  if (!list || list.length === 0) {
    pl.innerHTML = '<div class="empty-state">— no players online —</div>';
    return;
  }
  pl.innerHTML = "";
  list.forEach((name, i) => {
    if (!joinTimes[name]) joinTimes[name] = Date.now() - Math.floor(Math.random() * 3600000);
    const color = nameColor(name);
    const isOp = i === 0;
    const isNew = (Date.now() - joinTimes[name]) < 600000;
    const row = document.createElement("div");
    row.className = "player-row";
    row.innerHTML = `
      <div class="avatar" style="color:${color};border:1px solid ${color}33">${initials(name)}</div>
      <span class="pname">${name}</span>
      ${isOp ? '<span class="pbadge op">OP</span>' : ''}
      ${isNew && !isOp ? '<span class="pbadge new">NEW</span>' : ''}
      <span class="ptime">${elapsed(Date.now() - joinTimes[name])}</span>
      <div class="pdot"></div>`;
    pl.appendChild(row);
  });
}

function parsePlayers(raw) {
  if (!raw) return null;
  const m = raw.match(/There are \d+ of a max.*?: (.*)/i);
  if (m && m[1].trim()) return m[1].split(",").map(s => s.trim()).filter(Boolean);
  if (raw.includes("There are 0")) return [];
  return null;
}

function updateTPS(raw) {
  if (!raw) return;
  const m = raw.match(/(\d+(?:\.\d+)?)\s*TPS/i);
  if (m) {
    const v = parseFloat(m[1]);
    const el = document.getElementById("s-tps");
    el.textContent = v.toFixed(1);
    el.className = "stat-val " + (v >= 18 ? "good" : v >= 15 ? "warn" : "bad");
  }
}

function updateUptime() {
  const s = Math.floor((Date.now() - startTime) / 1000);
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60);
  document.getElementById("s-uptime").textContent = (h > 0 ? h + "h " : "") + m + "m";
}

async function checkStatus() {
  try {
    const res = await fetch(API + "/status", {
      headers: {"Authorization": "Bearer " + token}
    });
    if (res.status === 401) {
      sessionStorage.removeItem("mc_token");
      window.location.href = "index.html";
      return;
    }
    const dot = document.getElementById("sdot");
    const st = document.getElementById("stext");
    if (res.ok) {
      const data = await res.json();
      dot.className = "sdot on";
      st.textContent = "online";
      if (data.players) renderPlayers(data.players);
      if (data.tps) {
        const el = document.getElementById("s-tps");
        el.textContent = parseFloat(data.tps).toFixed(1);
        el.className = "stat-val " + (data.tps >= 18 ? "good" : data.tps >= 15 ? "warn" : "bad");
      }
      if (data.memory) document.getElementById("s-mem").textContent = data.memory;
    } else {
      dot.className = "sdot";
      st.textContent = "offline";
      renderPlayers([]);
    }
  } catch {
    document.getElementById("sdot").className = "sdot";
    document.getElementById("stext").textContent = "offline";
  }
}

async function refreshAll() {
  document.getElementById("rfbtn").textContent = "↻ ...";
  await checkStatus();
  updateUptime();
  document.getElementById("rfbtn").textContent = "↻ refresh";
}

document.getElementById("rfbtn").addEventListener("click", refreshAll);

// init
log("Panel loaded. Connecting to server...", "inf");
checkStatus();
updateUptime();
setInterval(checkStatus, 15000);
setInterval(updateUptime, 30000);
</script>
</body>
</html>
